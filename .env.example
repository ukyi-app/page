# 로컬 개발은 이 키들을 .env.local 에 채운다(Bun이 .env.local 자동 로드, .gitignore 처리됨).
# 프로덕션은 homelab conn 핸들(db-page-conn)이 PAGE_DATABASE_URL / PAGE_MIGRATE_DATABASE_URL 을,
# update-secrets가 ADMIN_TOKEN_SHA256(SealedSecret)을 주입한다.
PAGE_DATABASE_URL=
PAGE_MIGRATE_DATABASE_URL=
ADMIN_TOKEN_SHA256=
HTML_MAX_BYTES=1048576
JSON_MAX_BYTES=6307840
