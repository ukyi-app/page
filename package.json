{
  "name": "page",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test --max-concurrency=1 tests/integration",
    "typecheck": "tsc --noEmit",
    "token:hash": "bun scripts/hash-token.ts",
    "secret:seal": "bun tools/seal-secret.mts --config .app-config.yml --env .env",
    "smoke": "scripts/smoke.sh",
    "smoke:container": "scripts/container-smoke.sh",
    "web:install": "cd web && bun install",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun install --frozen-lockfile && bun run build"
  },
  "dependencies": {
    "hono": "^4.12.27",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.11.10",
    "typescript": "^6.0.3"
  }
}
